# DART OpenAPI key — get free key at https://opendart.fss.or.kr/uat/uia/eAPIPcpnInfoInqire.do
DART_API_KEY=your_dart_api_key_here

# KIS Open API — requires 한국투자증권 account, get at https://apiportal.koreainvestment.com/
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=your_account_number
KIS_ACCOUNT_PRODUCT_CODE=01

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gmail SMTP — requires Gmail with 2FA + App Password
# Get App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Recipients (comma-separated)
REPORT_RECIPIENTS=gsj2338@gmail.com,yeonheedo1127@gmail.com
